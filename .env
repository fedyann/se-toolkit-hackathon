# MindLog — environment variables
# Copy this file to .env and fill in your values.
# cp .env.example .env

# --- Docker image registry ---
# Leave empty to pull from Docker Hub directly.
# On the university network, set to the harbor proxy to avoid rate limits:
# REGISTRY_PREFIX_DOCKER_HUB=harbor.pg.innopolis.university/docker-hub-cache/
REGISTRY_PREFIX_DOCKER_HUB=

# --- PostgreSQL ---
POSTGRES_DB=mindlog
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# --- Caddy ---
CADDY_CONTAINER_PORT=80

# --- Qwen Code API (LLM) ---
# The API key for the Qwen Code API service.
# You should have received this during lab setup.
QWEN_CODE_API_KEY=2AJZjmGvjCP-d2iTCtExc9xzgHuxWlogto7L_hQ-BDCHnuubBSnPnxrJwpZYJ_9zaz2vPejt7k5_0Jp7cpnqZw
# Model name (default: coder-model).
QWEN_CODE_API_MODEL=coder-model
# Logging level for the Qwen API (debug, info, error).
QWEN_CODE_API_LOG_LEVEL=error
# Retry settings.
QWEN_CODE_API_MAX_RETRIES=5
QWEN_CODE_API_RETRY_DELAY_MS=1000
# Whether to use API key authentication.
QWEN_CODE_API_AUTH_USE=true
# Whether to log incoming requests.
QWEN_CODE_API_LOG_REQUESTS=true
